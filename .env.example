# MongoDB
# Option A: provide a full connection string
# MONGODB_URI=mongodb+srv://user:password@your-cluster.mongodb.net/?appName=Cluster0
# Option B: provide the parts (used when MONGODB_URI is not set)
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_CLUSTER_HOST=your-cluster.xxxxx.mongodb.net
# Database name (optional, defaults to ecommerce-nextjs)
# MONGODB_DB=ecommerce-nextjs

# NextAuth
NEXTAUTH_SECRET=
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App URL (no trailing slash — used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — only needed if the API runs on a different origin
# NEXT_PUBLIC_API_URL=http://localhost:3000
